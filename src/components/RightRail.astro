---
import KnowledgeGraph from './KnowledgeGraph.astro';
import { site } from '@/data/site';
import { getAllEntries, getAllTags, normalizeSlug } from '@/utils/content';
const entries = await getAllEntries();
const tags = getAllTags(entries).slice(0, 14);
const base = import.meta.env.BASE_URL;
const url = (href: string) => `${base}${href.replace(/^\//, '')}`;
---
<aside class="kb-right" aria-label="Page sidebar">
  <section class="linear-panel mb-5 rounded-2xl p-4">
    <div class="mb-3 flex items-center justify-between gap-3">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--muted-2)]">Preview</p>
        <h2 class="mt-1 text-base font-semibold tracking-[-0.03em]">Knowledge Graph</h2>
      </div>
      <a href={url('/graph/')} class="rounded-lg border border-[var(--line)] bg-[var(--tag)] px-2.5 py-1 text-xs text-[var(--muted)] hover:text-[var(--fg)]">Open</a>
    </div>
    <KnowledgeGraph variant="rail" limit={18} />
  </section>

  <section class="linear-panel mb-5 rounded-2xl p-4">
    <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--muted-2)]">Navigation</p>
    <nav class="space-y-1 text-sm text-[var(--muted)]">
      {site.nav.map((item) => <a class="flex items-center justify-between rounded-lg px-2 py-1.5 transition hover:bg-[var(--tag)] hover:text-[var(--fg)]" href={url(item.href)}><span>{item.label}</span><span class="text-[var(--muted-2)]">↗</span></a>)}
    </nav>
  </section>

  <section class="linear-panel rounded-2xl p-4">
    <p class="mb-3 font-mono text-[10px] uppercase tracking-[0.18em] text-[var(--muted-2)]">Tags & Concepts</p>
    <div class="flex flex-wrap gap-2">
      {tags.map(([tag, count]) => <a href={url(`/tags/${normalizeSlug(tag)}/`)} class="rounded-full border border-[var(--line-soft)] bg-[var(--tag)] px-2.5 py-1 text-[11px] text-[var(--muted)] transition hover:border-[var(--accent)] hover:text-[var(--fg)]">#{tag} <span class="text-[var(--muted-2)]">{count}</span></a>)}
    </div>
  </section>
</aside>
