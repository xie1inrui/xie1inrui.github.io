---
import { buildKnowledgeGraph, getAllEntries } from '@/utils/content';

interface Props {
  variant?: 'rail' | 'full';
  limit?: number;
}

const { variant = 'full', limit } = Astro.props;
const allEntries = await getAllEntries();
const { nodes, links } = buildKnowledgeGraph(allEntries, limit);
const graphData = JSON.stringify({ nodes, links });
const isRail = variant === 'rail';
---
<div class:list={['knowledge-graph-widget group relative overflow-hidden rounded-2xl border border-[var(--line)] bg-[radial-gradient(circle_at_50%_0%,rgba(113,112,255,.12),transparent_34rem),rgba(255,255,255,.018)] shadow-[inset_0_1px_0_rgba(255,255,255,.045)]', isRail ? 'h-[270px]' : 'h-[680px]']} data-variant={variant}>
  <div class="pointer-events-none absolute inset-0 bg-[linear-gradient(rgba(255,255,255,.018)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,.014)_1px,transparent_1px)] bg-[length:42px_42px] opacity-60"></div>
  <div class="pointer-events-none absolute left-3 top-3 z-10 rounded-xl border border-[var(--line)] bg-[var(--bg)]/70 px-2.5 py-1.5 font-mono text-[11px] text-[var(--muted)] backdrop-blur">
    {nodes.length} nodes · {links.length} links
  </div>
  {!isRail && (
    <div class="pointer-events-none absolute bottom-3 left-3 z-10 rounded-xl border border-[var(--line)] bg-[var(--bg)]/70 px-2.5 py-1.5 font-mono text-[11px] text-[var(--muted)] backdrop-blur">
      滚轮缩放 · 拖拽节点 · 点击圆点跳转
    </div>
  )}
  <svg class="h-full w-full cursor-grab active:cursor-grabbing" role="img" aria-label="交互式知识图谱"></svg>
  <div class="graph-tooltip pointer-events-none absolute hidden max-w-[260px] rounded-xl border border-[var(--line)] bg-[var(--bg)]/95 p-3 text-xs shadow-2xl backdrop-blur-xl">
    <div class="font-bold text-[var(--fg)]" data-title></div>
    <div class="mt-1 text-[var(--muted)]" data-summary></div>
  </div>
  <script type="application/json" class="graph-data" is:inline set:html={graphData}></script>
</div>

<script>
import { drag, forceCenter, forceCollide, forceLink, forceManyBody, forceSimulation, forceX, forceY, select, zoom } from 'd3';

type GraphNode = {
  id: string;
  label: string;
  type: 'section' | 'category' | 'content' | 'concept' | 'tag' | 'project' | string;
  url: string;
  summary: string;
  tags: string[];
  x?: number;
  y?: number;
  vx?: number;
  vy?: number;
  fx?: number | null;
  fy?: number | null;
};

type GraphLink = { source: string | GraphNode; target: string | GraphNode; type?: string };

type GraphPayload = { nodes: GraphNode[]; links: GraphLink[] };

const baseUrl = import.meta.env.BASE_URL;
const withBase = (path: string) => `${baseUrl}${path.replace(/^\//, '')}`;
const color = (type: string) => ({ section: '#8b5cf6', category: '#22d3ee', content: '#e5e7eb', concept: '#34d399', tag: '#94a3b8', project: '#f59e0b' }[type] || '#8a8f98');
const linkColor = (type?: string) => ({ belongs_to: '#7170ff', categorized_as: '#22d3ee', tagged_as: '#94a3b8', mentions: '#34d399', applies_to: '#f59e0b', references: '#a78bfa', related_to: '#64748b' }[type || ''] || '#64748b');
const radius = (node: GraphNode, compact: boolean) => {
  if (node.type === 'section') return compact ? 10 : 18;
  if (node.type === 'category' || node.type === 'project') return compact ? 7 : 12;
  if (node.type === 'concept') return compact ? 6 : 10;
  if (node.type === 'tag') return compact ? 4.5 : 7;
  return compact ? 5.5 : 9;
};
const labelVisible = (node: GraphNode, compact: boolean) => !compact && ['section', 'category', 'project', 'concept'].includes(node.type);

function initializeGraph(root: HTMLElement) {
  if (root.dataset.ready === 'true') return;
  root.dataset.ready = 'true';

  const svgElement = root.querySelector<SVGSVGElement>('svg');
  const dataElement = root.querySelector<HTMLScriptElement>('.graph-data');
  const tooltip = root.querySelector<HTMLElement>('.graph-tooltip');
  if (!svgElement || !dataElement) return;

  const compact = root.dataset.variant === 'rail';
  const data = JSON.parse(dataElement.textContent || '{"nodes":[],"links":[]}') as GraphPayload;
  const nodes = data.nodes.map((node) => ({ ...node }));
  const links = data.links.map((link) => ({ ...link }));
  const bounds = root.getBoundingClientRect();
  const width = Math.max(bounds.width, compact ? 250 : 700);
  const height = Math.max(bounds.height, compact ? 220 : 560);

  const svg = select(svgElement).attr('viewBox', `0 0 ${width} ${height}`);
  svg.selectAll('*').remove();

  const viewport = svg.append('g');
  const defs = svg.append('defs');
  const glow = defs.append('filter').attr('id', `graph-glow-${Math.random().toString(36).slice(2)}`).attr('x', '-80%').attr('y', '-80%').attr('width', '260%').attr('height', '260%');
  glow.append('feGaussianBlur').attr('stdDeviation', compact ? 2.2 : 3.5).attr('result', 'coloredBlur');
  const merge = glow.append('feMerge');
  merge.append('feMergeNode').attr('in', 'coloredBlur');
  merge.append('feMergeNode').attr('in', 'SourceGraphic');

  const linkLayer = viewport.append('g').attr('stroke-opacity', compact ? 0.28 : 0.22);
  const nodeLayer = viewport.append('g');

  const linkSelection = linkLayer
    .selectAll('line')
    .data(links)
    .join('line')
    .attr('stroke', (link) => linkColor(link.type))
    .attr('stroke-width', (link) => link.type === 'belongs_to' ? (compact ? 1.1 : 1.35) : (compact ? 0.75 : 1));

  const nodeSelection = nodeLayer
    .selectAll<SVGGElement, GraphNode>('g')
    .data(nodes)
    .join('g')
    .attr('class', 'graph-node')
    .style('cursor', 'pointer')
    .on('click', (event, node) => {
      event.preventDefault();
      if ((event.defaultPrevented || (event as PointerEvent).metaKey) && !node.url) return;
      window.location.href = withBase(node.url);
    })
    .on('mouseenter', function (_event, node) {
      select(this).select('circle').transition().duration(130).attr('r', radius(node, compact) + 4).attr('stroke-width', 2.2).attr('fill-opacity', 1);
      if (tooltip) {
        tooltip.classList.remove('hidden');
        const title = tooltip.querySelector<HTMLElement>('[data-title]');
        const summary = tooltip.querySelector<HTMLElement>('[data-summary]');
        if (title) title.textContent = node.label;
        if (summary) summary.textContent = node.summary || node.type;
      }
    })
    .on('mousemove', (event) => {
      if (!tooltip) return;
      const rect = root.getBoundingClientRect();
      tooltip.style.left = `${Math.min(event.clientX - rect.left + 12, rect.width - 250)}px`;
      tooltip.style.top = `${Math.min(event.clientY - rect.top + 12, rect.height - 90)}px`;
    })
    .on('mouseleave', function (_event, node) {
      select(this).select('circle').transition().duration(130).attr('r', radius(node, compact)).attr('stroke-width', 1.4);
      tooltip?.classList.add('hidden');
    });

  nodeSelection
    .append('circle')
    .attr('r', (node) => radius(node, compact))
    .attr('fill', (node) => color(node.type))
    .attr('fill-opacity', (node) => node.type === 'tag' ? 0.62 : 0.94)
    .attr('stroke', 'rgba(255,255,255,.72)')
    .attr('stroke-opacity', (node) => node.type === 'content' ? 0.55 : 0.35)
    .attr('stroke-width', 1.25)
    .attr('filter', compact ? null : `url(#${glow.attr('id')})`);

  nodeSelection
    .filter((node) => labelVisible(node, compact))
    .append('text')
    .attr('x', 13)
    .attr('y', 4)
    .attr('font-size', 11)
    .attr('font-family', 'Inter, system-ui, sans-serif')
    .attr('fill', 'var(--muted)')
    .text((node) => node.label.length > 22 ? `${node.label.slice(0, 22)}…` : node.label);

  const simulation = forceSimulation<GraphNode>(nodes)
    .force('link', forceLink<GraphNode, GraphLink>(links).id((node) => node.id).distance(compact ? 34 : 78).strength(compact ? 0.56 : 0.34))
    .force('charge', forceManyBody().strength(compact ? -42 : -180))
    .force('center', forceCenter(width / 2, height / 2))
    .force('collide', forceCollide<GraphNode>().radius((node) => radius(node, compact) + (compact ? 4 : 12)).iterations(2))
    .force('x', forceX<GraphNode>(width / 2).strength(0.018))
    .force('y', forceY<GraphNode>(height / 2).strength(0.018))
    .alpha(compact ? 0.9 : 1);

  function ticked() {
    const padding = compact ? 16 : 28;
    for (const node of nodes) {
      node.x = Math.max(padding, Math.min(width - padding, node.x || width / 2));
      node.y = Math.max(padding, Math.min(height - padding, node.y || height / 2));
    }
    linkSelection
      .attr('x1', (link) => (link.source as GraphNode).x || 0)
      .attr('y1', (link) => (link.source as GraphNode).y || 0)
      .attr('x2', (link) => (link.target as GraphNode).x || 0)
      .attr('y2', (link) => (link.target as GraphNode).y || 0);
    nodeSelection.attr('transform', (node) => `translate(${node.x || 0},${node.y || 0})`);
  }

  simulation.on('tick', ticked);

  const dragBehavior = drag<SVGGElement, GraphNode>()
    .on('start', (event, node) => {
      if (!event.active) simulation.alphaTarget(0.3).restart();
      node.fx = node.x;
      node.fy = node.y;
    })
    .on('drag', (event, node) => {
      node.fx = event.x;
      node.fy = event.y;
    })
    .on('end', (event, node) => {
      if (!event.active) simulation.alphaTarget(0);
      node.fx = null;
      node.fy = null;
    });

  nodeSelection.call(dragBehavior);

  svg.call(
    zoom<SVGSVGElement, unknown>()
      .scaleExtent(compact ? [0.8, 2.4] : [0.45, 4])
      .on('zoom', (event) => viewport.attr('transform', event.transform.toString()))
  );

  svg.on('pointermove', (event) => {
    const [mx, my] = event.pointerType ? [event.offsetX, event.offsetY] : [width / 2, height / 2];
    for (const node of nodes) {
      const dx = mx - (node.x || width / 2);
      const dy = my - (node.y || height / 2);
      const dist2 = Math.max(dx * dx + dy * dy, 1600);
      const influence = compact ? 90 / dist2 : 140 / dist2;
      node.vx = (node.vx || 0) + dx * influence;
      node.vy = (node.vy || 0) + dy * influence;
    }
    simulation.alphaTarget(compact ? 0.08 : 0.05).restart();
  });

  svg.on('pointerleave', () => simulation.alphaTarget(0));
}

document.querySelectorAll<HTMLElement>('.knowledge-graph-widget').forEach(initializeGraph);
</script>
