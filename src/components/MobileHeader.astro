---
import { site } from '@/data/site';
const base = import.meta.env.BASE_URL;
const url = (href: string) => `${base}${href.replace(/^\//, '')}`;
---
<header class="fixed inset-x-0 top-0 z-40 border-b border-[var(--line)] bg-[var(--bg)]/82 px-4 py-3 backdrop-blur-xl lg:hidden">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-3">
    <a href={url('/')} class="flex items-center gap-2 font-semibold tracking-[-0.03em] text-[var(--fg)]"><span class="grid h-7 w-7 place-items-center rounded-lg bg-[var(--accent-2)] text-xs text-white">XL</span>{site.shortTitle}</a>
    <nav class="flex items-center gap-3 overflow-x-auto text-sm text-[var(--muted)]">
      <a href={url('/research/')}>Research</a>
      <a href={url('/notes/')}>Notes</a>
      <a href={url('/projects/')}>Projects</a>
      <a href={url('/graph/')}>Graph</a>
      <button id="mobile-theme-toggle" class="rounded-lg border border-[var(--line)] bg-[var(--tag)] px-2 py-1" aria-label="Toggle color mode">◐</button>
    </nav>
  </div>
</header>
