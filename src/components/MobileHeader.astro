---
import { site } from '@/data/site';
const base = import.meta.env.BASE_URL;
const url = (href: string) => `${base}${href.replace(/^\//, '')}`;
---
<header class="fixed inset-x-0 top-0 z-40 border-b border-[var(--line)] bg-[var(--bg)]/86 px-4 py-3 backdrop-blur-xl lg:hidden">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-3">
    <a href={url('/')} class="font-mono text-sm font-bold text-[var(--accent)]">{site.shortTitle}</a>
    <nav class="flex items-center gap-3 overflow-x-auto text-sm text-[var(--muted)]">
      <a href={url('/about/')}>About</a>
      <a href={url('/cv/')}>CV</a>
      <a href={url('/research/')}>Research</a>
      <a href={url('/blog/')}>Blog</a>
      <a href={url('/notes/')}>Notes</a>
      <button id="mobile-theme-toggle" class="rounded border border-[var(--line)] px-2 py-1" aria-label="Toggle dark mode">◐</button>
    </nav>
  </div>
</header>
