---
import { site } from '@/data/site';
const current = Astro.url.pathname;
const base = import.meta.env.BASE_URL;
const url = (href: string) => `${base}${href.replace(/^\//, '')}`;
const icons: Record<string, string> = {
  Home: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4.75 10.4 12 4.75l7.25 5.65v8.35a.5.5 0 0 1-.5.5h-4.5v-5.5h-4.5v5.5h-4.5a.5.5 0 0 1-.5-.5V10.4Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>',
  About: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 4.75a7.25 7.25 0 1 0 0 14.5 7.25 7.25 0 0 0 0-14.5Z" stroke="currentColor" stroke-width="1.7"/><path d="M12 11.5v4.25M12 8.25h.01" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg>',
  CV: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7.25 4.75h7.7l2.8 2.85v11.65H7.25V4.75Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M14.75 4.9v3h2.85M9.75 11.25h4.5M9.75 14.25h4.5M9.75 17.25h2.5" stroke="currentColor" stroke-width="1.55" stroke-linecap="round"/></svg>',
  Research: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.75 5.25h10.5v13.5H6.75V5.25Z" stroke="currentColor" stroke-width="1.7"/><path d="M9.25 8.25h5.5M9.25 11.25h5.5M9.25 14.25h3.25" stroke="currentColor" stroke-width="1.55" stroke-linecap="round"/><path d="M17.25 5.25l-2.5 2.4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>',
  Notes: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7.25 17.25 6.75 20l2.75-.5 8.55-8.55a2.12 2.12 0 0 0-3-3L7.25 17.25Z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/><path d="m14.25 8.75 3 3" stroke="currentColor" stroke-width="1.55" stroke-linecap="round"/></svg>',
  Projects: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5.25 7.75a1 1 0 0 1 1-1h4.25l1.5 1.75h5.75a1 1 0 0 1 1 1v7.75a1 1 0 0 1-1 1H6.25a1 1 0 0 1-1-1v-9.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M5.5 10.25h13" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/></svg>',
  Blog: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.25 5.25h11.5v13.5H6.25V5.25Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><path d="M9.25 9.25h5.5M9.25 12.25h5.5M9.25 15.25h3.5" stroke="currentColor" stroke-width="1.55" stroke-linecap="round"/><path d="M17.75 5.25 15 8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>',
  Graph: '<svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M7.5 8.5a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5ZM16.5 20a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5ZM17 8.75a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" stroke="currentColor" stroke-width="1.7"/><path d="m9.55 7.55 4.9 8.25M9.75 7.35l5.1-.15" stroke="currentColor" stroke-width="1.45" stroke-linecap="round"/></svg>'
};
---
<aside class="kb-sidebar" aria-label="Main navigation">
  <div class="linear-panel rounded-2xl p-4">
    <a href={url('/')} class="group flex items-center gap-3">
      <span class="grid h-10 w-10 place-items-center rounded-xl border border-[var(--line)] bg-[var(--tag)] text-[var(--accent)] shadow-[0_0_28px_rgba(113,112,255,.25)]">XL</span>
      <span>
        <span class="block text-[15px] font-semibold tracking-[-0.03em] text-[var(--fg)]">{site.shortTitle}</span>
        <span class="mt-0.5 block font-mono text-[11px] text-[var(--muted)]">research OS</span>
      </span>
    </a>
    <p class="mt-4 text-[13px] leading-6 text-[var(--muted)]">{site.description}</p>
  </div>

  <a href={url('/search/')} class="mt-4 flex items-center justify-between rounded-xl border border-[var(--line)] bg-[var(--card)] px-3 py-2.5 text-sm text-[var(--muted)] transition hover:border-[var(--accent)] hover:bg-[var(--card-hover)] hover:text-[var(--fg)]">
    <span class="flex items-center gap-2"><span class="grid h-5 w-5 place-items-center"><svg viewBox="0 0 24 24" fill="none" class="h-4 w-4"><path d="m15.5 15.5 4 4M10.75 17.25a6.5 6.5 0 1 1 0-13 6.5 6.5 0 0 1 0 13Z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg></span><span>Search notes</span></span>
    <span class="rounded border border-[var(--line-soft)] px-1.5 py-0.5 font-mono text-[10px] text-[var(--muted-2)]">/</span>
  </a>

  <div class="mt-4 flex items-center justify-between rounded-xl border border-[var(--line-soft)] bg-[var(--card)] px-3 py-2">
    <span class="text-xs text-[var(--muted)]">Interface</span>
    <button id="theme-toggle" class="rounded-lg border border-[var(--line)] bg-[var(--tag)] px-2.5 py-1 text-xs text-[var(--muted)] transition hover:text-[var(--fg)]" aria-label="Toggle color mode">◐ mode</button>
  </div>

  <p class="mb-2 mt-7 px-2 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--muted-2)]">Navigation</p>
  <nav class="space-y-1.5">
    {site.nav.map((item) => {
      const active = current === item.href || (item.href !== '/' && current.startsWith(item.href));
      return <a href={url(item.href)} class:list={["group relative flex items-center gap-3 rounded-2xl px-3 py-2.5 text-sm transition duration-200", active ? "border border-[rgba(255,255,255,.13)] bg-[linear-gradient(180deg,rgba(255,255,255,.085),rgba(255,255,255,.035))] text-[var(--fg)] shadow-[inset_0_1px_0_rgba(255,255,255,.08),0_16px_34px_rgba(0,0,0,.24)]" : "text-[var(--muted)] hover:bg-[var(--tag)] hover:text-[var(--fg)]"]}>
        <span class:list={["grid h-9 w-9 shrink-0 place-items-center rounded-xl border transition duration-200 [&_svg]:h-[18px] [&_svg]:w-[18px]", active ? "border-[rgba(255,255,255,.16)] bg-[linear-gradient(135deg,#7c7cff,#5e6ad2)] text-white shadow-[0_0_28px_rgba(113,112,255,.36)]" : "border-[var(--line-soft)] bg-[rgba(255,255,255,.035)] text-[var(--accent)] group-hover:border-[rgba(113,112,255,.35)] group-hover:bg-[rgba(113,112,255,.10)] group-hover:text-[var(--accent-hover)]"]} set:html={icons[item.label] ?? item.icon}></span>
        <span class="tracking-[-0.02em]">{item.label}</span>
        {active && <span class="ml-auto h-1.5 w-1.5 rounded-full bg-[var(--accent-hover)] shadow-[0_0_16px_rgba(130,143,255,.85)]"></span>}
      </a>;
    })}
  </nav>

  <div class="mt-8 rounded-2xl border border-[var(--line-soft)] bg-[var(--card)] p-4">
    <p class="mb-3 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--muted-2)]">Research Focus</p>
    <div class="flex flex-wrap gap-2">
      {site.researchDirections.map((item) => <span class="rounded-full border border-[var(--line)] bg-[var(--tag)] px-2.5 py-1 text-[11px] text-[var(--muted)]">{item}</span>)}
    </div>
  </div>
</aside>
<script>
const buttons = document.querySelectorAll<HTMLButtonElement>('#theme-toggle, #mobile-theme-toggle');
for (const button of buttons) button.addEventListener('click', () => {
  const isLight = !document.documentElement.classList.contains('light');
  document.documentElement.classList.toggle('light', isLight);
  document.documentElement.classList.toggle('dark', !isLight);
  localStorage.setItem('theme', isLight ? 'light' : 'dark');
});
</script>
