---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCard from '@/components/ContentCard.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout title="Blog" description="Long-form writing">
  <header class="mb-8">
    <p class="mb-3 text-sm text-[var(--muted)]">Blog</p>
    <h1 class="text-4xl font-black tracking-[-0.07em] sm:text-5xl">Blog</h1>
    <p class="mt-4 leading-8 text-[var(--muted)]">Long-form writing, research reflections, engineering essays, and occasional notes on building AI systems.</p>
  </header>
  <div>{posts.map((entry) => <ContentCard entry={entry} />)}</div>
</BaseLayout>
