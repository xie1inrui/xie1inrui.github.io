---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCard from '@/components/ContentCard.astro';
import SearchBox from '@/components/SearchBox.astro';
import { site } from '@/data/site';
import { getAllEntries, getAllTags, normalizeSlug } from '@/utils/content';
const base = import.meta.env.BASE_URL;
const url = (href: string) => `${base}${href.replace(/^\//, '')}`;
const entries = await getAllEntries();
const recent = entries.slice(0, 6);
const tags = getAllTags(entries).slice(0, 20);
const entrances = [
  { href: '/about/', title: 'About', desc: 'About me, current focus, contact, and links.', icon: '◇' },
  { href: '/cv/', title: 'CV', desc: 'Education, experience, skills, and selected projects.', icon: '▤' },
  { href: '/research/', title: 'Research', desc: 'Paper readings and research topics in AI systems.', icon: '◫' },
  { href: '/notes/', title: 'Notes', desc: 'Technical notes, server tools, and reusable knowledge.', icon: '✎' },
  { href: '/projects/', title: 'Projects', desc: 'Project branches, experiment logs, and retrospectives.', icon: '▣' },
  { href: '/blog/', title: 'Blog', desc: 'Learning life, internship reflections, and personal writing.', icon: '✦' },
  { href: '/graph/', title: 'Graph', desc: 'Explore sections, concepts, notes, papers, and projects.', icon: '◎' }
];
---
<BaseLayout>
  <section class="pb-10">
    <p class="mb-3 text-sm text-[var(--muted)]">Personal homepage & knowledge archive</p>
    <h1 class="text-5xl font-black leading-none tracking-[-0.08em] sm:text-6xl">{site.author}</h1>
    <p class="mt-5 max-w-2xl text-xl leading-8 text-[var(--muted)]">Research-oriented full-stack engineer focusing on AI systems, LLM inference, distributed training, and AI infrastructure.</p>
  </section>

  <section class="border-y border-[var(--line)] py-8">
    <h2 class="text-2xl font-black tracking-[-0.05em]">Start Here</h2>
    <div class="mt-5 grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
      {entrances.map((item) => (
        <a href={url(item.href)} class="group rounded-xl border border-[var(--line)] bg-[var(--panel)]/35 p-4 transition hover:border-[var(--accent)] hover:bg-[var(--panel)]">
          <div class="flex items-center gap-3">
            <span class="text-xl text-[var(--accent)]">{item.icon}</span>
            <h3 class="font-bold tracking-tight group-hover:text-[var(--accent)]">{item.title}</h3>
          </div>
          <p class="mt-3 text-sm leading-6 text-[var(--muted)]">{item.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="border-b border-[var(--line)] py-8">
    <h2 class="text-2xl font-black tracking-[-0.05em]">Research Focus</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      {site.researchDirections.map((item) => <span class="rounded-md bg-[var(--tag)] px-2.5 py-1 text-sm text-[var(--muted)]">{item}</span>)}
    </div>
  </section>

  <section class="grid gap-8 py-8 xl:grid-cols-[1fr_250px]">
    <div>
      <h2 class="mb-4 text-lg font-black tracking-tight">Recent Updates</h2>
      <div>{recent.map((entry)=><ContentCard entry={entry}/>)}</div>
    </div>
    <aside class="space-y-5 xl:hidden">
      <SearchBox />
      <div class="rounded-lg border border-[var(--line)] bg-[var(--panel)]/45 p-4">
        <h2 class="font-bold">Tags</h2>
        <div class="mt-4 flex flex-wrap gap-2">{tags.map(([tag,count])=><a href={url(`/tags/${normalizeSlug(tag)}/`)} class="rounded-md bg-[var(--tag)] px-2 py-1 text-xs text-[var(--muted)]">#{tag} {count}</a>)}</div>
      </div>
    </aside>
  </section>
</BaseLayout>
