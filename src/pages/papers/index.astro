---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCard from '@/components/ContentCard.astro';
import { getCollection } from 'astro:content';
const entries = (await getCollection('papers')).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf());
---
<BaseLayout title="论文阅读" description="按问题意识记录系统论文：动机、架构、方法、实验和可迁移经验。"><header class="mb-8"><h1 class="text-4xl font-semibold tracking-[-0.05em]">论文阅读</h1><p class="mt-3 text-zinc-500">按问题意识记录系统论文：动机、架构、方法、实验和可迁移经验。</p></header><div class="grid gap-4">{entries.map((entry)=><ContentCard entry={entry}/>)}</div></BaseLayout>
