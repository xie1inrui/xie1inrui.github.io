---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCard from '@/components/ContentCard.astro';
import { getCollection } from 'astro:content';
const entries = (await getCollection('notes')).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf());
---
<BaseLayout title="技术笔记" description="沉淀核心概念、关键代码、命令记录和工程踩坑。"><header class="mb-8"><h1 class="text-4xl font-semibold tracking-[-0.05em]">技术笔记</h1><p class="mt-3 text-zinc-500">沉淀核心概念、关键代码、命令记录和工程踩坑。</p></header><div class="grid gap-4">{entries.map((entry)=><ContentCard entry={entry}/>)}</div></BaseLayout>
