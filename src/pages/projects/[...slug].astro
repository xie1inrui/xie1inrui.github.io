---
import { getCollection, render } from 'astro:content';
import ContentLayout from '@/layouts/ContentLayout.astro';
export async function getStaticPaths() { const entries = await getCollection('projects'); return entries.map((entry)=>({ params: { slug: entry.slug }, props: { entry } })); }
const { entry } = Astro.props;
const { Content } = await render(entry);
---
<ContentLayout entry={entry}><Content /></ContentLayout>
