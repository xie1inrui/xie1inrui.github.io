---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCard from '@/components/ContentCard.astro';
import { getCollection } from 'astro:content';
const entries = (await getCollection('projects')).sort((a,b)=>b.data.date.valueOf()-a.data.date.valueOf());
---
<BaseLayout title="项目归档" description="记录项目目标、实现路径、实验结论与后续问题。"><header class="mb-8"><h1 class="text-4xl font-semibold tracking-[-0.05em]">项目归档</h1><p class="mt-3 text-zinc-500">记录项目目标、实现路径、实验结论与后续问题。</p></header><div class="grid gap-4">{entries.map((entry)=><ContentCard entry={entry}/>)}</div></BaseLayout>
